                <span class="h-5 w-px bg-white/20"></span>

                <a
                    href="tel:+51944898564"
                    class="inline-flex items-center gap-2 hover:text-white transition-colors"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
