---
// src/components/TechnicalSpecs.astro
---

<section id="especificaciones-tecnicas" class="w-full bg-[#0A0E1A] py-16 md:py-24 px-4 sm:px-6 relative overflow-hidden text-white border-b border-slate-900/50">
    
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#1e293b_1px,transparent_1px),linear-gradient(to_bottom,#1e293b_1px,transparent_1px)] bg-size-[4rem_4rem] opacity-10 pointer-events-none"></div>

    <div class="max-w-6xl mx-auto space-y-12 relative z-10">
        
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 border-b border-slate-800/60 pb-8">
            <div class="space-y-2">
                <span class="text-[10px] font-mono tracking-widest text-blue-400 uppercase font-bold">Datos de Ingeniería • Ensayo</span>
                <h2 class="text-3xl md:text-5xl font-black tracking-tight text-white font-['Arial_Narrow',sans-serif-condensed] uppercase leading-none">
                    Especificaciones <span class="text-blue-500">Técnicas</span>
                </h2>
            </div>
            <p class="text-slate-400 text-xs md:text-sm max-w-sm font-normal leading-relaxed">
                Datos duros y tolerancia de materiales probados en laboratorio. Información certificada para aprobación en proyectos y obras.
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
            
            <div class="lg:col-span-7 bg-[#0D1220] border border-slate-800/40 rounded-3xl p-5 sm:p-6 md:p-8 flex flex-col justify-between hover:border-blue-500/20 transition-all duration-300 shadow-xl shadow-black/30">
                <div class="space-y-6 w-full">
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
                        <span class="text-[10px] font-mono text-blue-400 bg-blue-500/10 px-2.5 py-1 rounded-md font-bold uppercase tracking-wider border border-blue-500/20">Estructura y Dimensiones</span>
                        <span class="text-[11px] font-mono text-slate-500">Matriz Estándar</span>
                    </div>
                    
                    <h3 class="text-lg sm:text-xl md:text-2xl font-black text-white uppercase tracking-tight leading-tight font-['Arial_Narrow',sans-serif-condensed]">Propiedades Físicas del Panel</h3>
                    
                    <div class="w-full overflow-x-auto text-xs font-mono">
                        <table class="w-full text-left divide-y divide-slate-800/60">
                            <tbody>
                                <tr class="border-b border-slate-800/40">
                                    <td class="py-3 pr-4 text-slate-400 align-top">Composición Estructural</td>
                                    <td class="py-3 text-white font-bold text-right wrap-break-word align-top">68% Resina / 32% Fibra de Vidrio</td>
                                </tr>
                                <tr class="border-b border-slate-800/40">
                                    <td class="py-3 pr-4 text-slate-400 align-top">Dimensiones del Panel</td>
                                    <td class="py-3 text-white font-bold text-right wrap-break-word align-top">1220 x 3660 mm / 1000 x 4000 mm</td>
                                </tr>
                                <tr class="border-b border-slate-800/40">
                                    <td class="py-3 pr-4 text-slate-400 align-top">Peso Promedio Estructural</td>
                                    <td class="py-3 text-white font-bold text-right wrap-break-word align-top">21.5 Kg / m²</td>
                                </tr>
                                <tr>
                                    <td class="py-3 pr-4 text-slate-400 align-top">Acabado de Superficie</td>
                                    <td class="py-3 text-blue-400 font-bold text-right wrap-break-word align-top">Grit (Antideslizante de alta fricción)</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="bg-slate-900/40 border border-slate-800/80 rounded-2xl p-4 mt-4">
                        <h4 class="text-xs font-mono font-bold text-amber-400 uppercase tracking-wider mb-1">⚙️ Sistema de Fijación Recomendado</h4>
                        <p class="text-slate-400 text-xs leading-relaxed">
                            Uso estricto de <strong class="text-slate-200">Clip Tipo M en Acero Inoxidable (Inox M-50)</strong> con perno, tuerca y arandela de 1/4" x 2". Se exige anclar un mínimo de <strong class="text-white">4 fijaciones por cada m²</strong> de rejilla.
                        </p>
                    </div>
                </div>

                <div class="pt-6 text-[11px] font-mono text-slate-400 uppercase tracking-wider flex items-center gap-2 border-t border-slate-800/40 mt-6">
                    <span class="w-1.5 h-1.5 bg-blue-500 rounded-full"></span> Material Dieléctrico • Ignífugo • Liviano
                </div>
            </div>

            <div class="lg:col-span-5 bg-[#0D1220] border border-slate-800/40 rounded-3xl p-5 sm:p-6 md:p-8 flex flex-col justify-between hover:border-amber-500/20 transition-all duration-300 shadow-xl shadow-black/30">
                <div class="space-y-6">
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
                        <span class="text-[10px] font-mono text-amber-400 bg-amber-500/10 px-2.5 py-1 rounded-md font-bold uppercase tracking-wider border border-amber-500/20">Límites Térmicos</span>
                        <span class="text-[11px] font-mono text-slate-500">Grado Industrial</span>
                    </div>
                    
                    <h3 class="text-lg sm:text-xl md:text-2xl font-black text-white uppercase tracking-tight leading-tight font-['Arial_Narrow',sans-serif-condensed]">Inmunidad Química</h3>
                    <p class="text-slate-400 text-xs font-normal leading-relaxed">
                        Tolerancia térmica máxima sugerida para resinas de grado Premium expuestas a fluidos agresivos comunes en minas y refinerías peruanas:
                    </p>

                    <div class="space-y-3 font-mono text-xs pt-2">
                        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-2 bg-slate-900/30 p-3 rounded-xl border border-slate-800/40">
                            <span class="text-slate-300 flex items-center gap-2 min-w-0">💧 Agua de Mar</span>
                            <span class="text-emerald-400 font-bold sm:text-right shrink-0">Hasta 100°C</span>
                        </div>
                        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-2 bg-slate-900/30 p-3 rounded-xl border border-slate-800/40">
                            <span class="text-slate-300 flex items-center gap-2 min-w-0">🧪 Ácido Clorhídrico (15%)</span>
                            <span class="text-emerald-400 font-bold sm:text-right shrink-0">Hasta 100°C</span>
                        </div>
                        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-2 bg-slate-900/30 p-3 rounded-xl border border-slate-800/40">
                            <span class="text-slate-300 flex items-center gap-2 min-w-0">⛽ Combustible Diésel</span>
                            <span class="text-emerald-400 font-bold sm:text-right shrink-0">Hasta 60°C</span>
                        </div>
                        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-2 bg-slate-900/30 p-3 rounded-xl border border-slate-800/40">
                            <span class="text-slate-300 flex items-center gap-2 min-w-0">🧂 Salmuera Avanzada</span>
                            <span class="text-emerald-400 font-bold sm:text-right shrink-0">Hasta 100°C</span>
                        </div>
                    </div>
                </div>

                <div class="pt-6 text-[11px] font-mono text-slate-400 uppercase tracking-wider flex items-center gap-2 border-t border-slate-800/40 mt-6">
                    <span class="w-1.5 h-1.5 bg-amber-500 rounded-full"></span> Cero Corrosión en Entornos Ácidos
                </div>
            </div>

        </div>
    </div>
</section>