---
// src/components/Hero.astro
---

<section
    id="home"
    class="w-full min-h-[85vh] pt-28 pb-16 md:py-32 flex items-center justify-center relative bg-[#0E1728] overflow-hidden"
>
    <div
        class="absolute inset-0 opacity-[0.16] pointer-events-none mask-[radial-gradient(ellipse_80%_70%_at_50%_50%,#000_60%,transparent_100%)]"
        style="background-image: 
        linear-gradient(to right, rgba(59,130,246,0.4) 1px, transparent 1px),
        linear-gradient(to bottom, rgba(59,130,246,0.4) 1px, transparent 1px);
      background-size: 48px 48px;"
    >
    </div>

    <div
        class="relative z-10 w-full max-w-6xl mx-auto px-6 md:px-12 flex flex-col items-center text-center"
    >
        <div class="flex items-center justify-center gap-3 mb-6">
            <span class="w-8 h-0.5 bg-blue-600"></span>
            <span
                class="text-xs font-bold tracking-widest text-blue-500 uppercase"
            >
                Importación Directa • FRP Grating • Perú
            </span>
        </div>

        <h1
            class="text-5xl md:text-[5.5rem] font-black text-white tracking-tighter uppercase max-w-4xl leading-[0.95] mb-8 font-['Arial_Narrow',sans-serif-condensed,sans-serif] font-stretch-75 select-none"
        >
            Rejillas de <br />
            <span class="text-blue-600 block my-1">Fibra de</span>
            Vidrio FRP
        </h1>

        <p
            class="text-sm md:text-base text-slate-400 max-w-2xl mx-auto mb-10 leading-relaxed font-normal text-center justify-center"
        >
            Importamos y distribuimos rejillas FRP Grating de alta resistencia
            para industria, minería y construcción en todo el Perú. Durabilidad
            superior al acero, sin corrosión.
        </p>

        <div
            class="flex flex-row items-center justify-center gap-4 w-full sm:w-auto"
        >
            <a
                href="#productos"
                class="bg-blue-600 hover:bg-blue-500 text-white font-bold px-6 py-3.5 rounded-sm transition-all duration-200 flex items-center gap-3 text-sm tracking-wide cursor-pointer shadow-md shadow-blue-600/10"
            >
                Ver catálogo <span class="text-base">&rarr;</span>
            </a>

            <a
                href="#simulator"
                class="bg-transparent hover:bg-blue-600/20 text-blue-400 font-semibold px-6 py-3.5 rounded-sm border border-blue-500 hover:border-blue-400 transition-all duration-200 text-sm tracking-wide cursor-pointer shadow-md shadow-blue-500/10"
            >
                Simular cotización
            </a>
        </div>
    </div>

    <a
        href="https://wa.me/51984649227"
        target="_blank"
        rel="noopener noreferrer"
        class="fixed bottom-6 right-6 z-50 animacion-latido bg-white text-[#25D366] font-medium px-4 py-2.5 rounded-sm flex items-center gap-2 border-2 border-[#25D366] shadow-xl hover:shadow-[0_0_24px_rgba(37,211,102,0.3)] hover:scale-105 transition-all duration-200 cursor-pointer text-sm"
    >
        <svg
            class="w-8 h-8 fill-current"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
        >
            <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"
            ></path>
        </svg>
        Cotizar ahora
    </a>

    <style>
        .animacion-latido {
            animation: latidoCorazon 2.5s infinite;
        }
        @keyframes latidoCorazon {
            0% {
                transform: scale(1);
            }
            10% {
                transform: scale(1.1);
            }
            20% {
                transform: scale(1);
            }
            30% {
                transform: scale(1.1);
            }
            40% {
                transform: scale(1);
            }
            100% {
                transform: scale(1);
            }
        }
    </style>
</section>
